{
    "name": "@repo/product-db",
    "version": "0.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
    "build": "tsc && cp -r src/generated dist/generated",
    "postinstall": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate deploy --config prisma.config.ts",
    "db:studio": "prisma studio --config prisma.config.ts"
  },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@types/pg": "^8.20.0",
        "prisma": "^7.7.0",
        "@repo/typescript-config": "workspace:*"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "dotenv": "^17.4.2",
        "pg": "^8.20.0",
        "tsx": "^4.21.0"
    },
    "engines": {
        "node": ">=20.19.0"
    },
      "exports": {
        ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
